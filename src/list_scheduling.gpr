project List_Scheduling is

   -- Specify the directory where the source code resides
   for Source_Dirs use ("src", "tests");
   
   -- Define where compilation artifacts (.o and .ali) should be placed
   for Object_Dir use "obj";
   
   package Compiler is
      -- Uses Ada 2012 specification standard and applies level 2 optimization
      for Default_Switches ("Ada") use ("-O2", "-gnat12", "-gnatwa");
   end Compiler;

end List_Scheduling;
